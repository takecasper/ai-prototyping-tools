# ──────────────────────────────────────────────────────────────────
# PRIVATE-BY-DEFAULT
# Nothing in this repo is tracked unless explicitly allow-listed below.
# To promote a file/folder to shareable: place it under shared/, add it
# to the app allow-list below, or add a `!` un-ignore rule here. Be
# deliberate — anything tracked becomes visible to the design team when
# this repo is shared.
#
# Two shareable roots: the prototyping tool (this app, at repo root) and
# shared/ (curated design-system docs). Everything else stays private.
# ──────────────────────────────────────────────────────────────────

# 1. Ignore everything by default.
*

# 2. Keep these meta files visible (root only).
!.gitignore
!/README.md
!/AGENTS.md

# 3. Shareable zone — anything placed here is tracked.
!shared/
!shared/**

# 4. The prototyping tool, flattened to repo root (source only; installed
#    deps and build output stay ignored). Every rule is anchored with a
#    leading `/` so it cannot un-ignore a same-named file in a private
#    folder. Add new top-level app files here to track them.
!/eslint-plugin-canonical/
!/eslint-plugin-canonical/**
!/eslint.config.js
!/index.html
!/package.json
!/package-lock.json
!/src/
!/src/**
!/tsconfig.json
!/vite.config.ts
/node_modules/
/dist/

# 5. OS / editor noise — stays ignored even inside shared/.
.DS_Store
**/.DS_Store
*.swp
.idea/
.vscode/

# AI codex index files (regenerated on session start and pre-commit)
ai-codex/

# Codex path-rules config — local tooling only, never shared.
/codex.yaml
